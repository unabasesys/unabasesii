{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "steps": {
    "install": {
      "variables": {
        "PLAYWRIGHT_BROWSERS_PATH": "/app/.playwright"
      },
      "commands": [
        "...",
        "playwright install chromium"
      ]
    }
  },
  "deploy": {
    "aptPackages": [
      "libasound2",
      "libatk-bridge2.0-0",
      "libatk1.0-0",
      "libatspi2.0-0",
      "libdbus-1-3",
      "libexpat1",
      "libgbm1",
      "libglib2.0-0",
      "libnspr4",
      "libnss3",
      "libx11-6",
      "libxcb1",
      "libxcomposite1",
      "libxdamage1",
      "libxext6",
      "libxfixes3",
      "libxkbcommon0",
      "libxrandr2"
    ],
    "variables": {
      "PLAYWRIGHT_BROWSERS_PATH": "/app/.playwright"
    },
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8001}"
  }
}
