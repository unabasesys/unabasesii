{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "steps": {
    "install": {
      "inputs": [{ "local": true, "include": ["."] }],
      "commands": [
        "pip install --no-cache-dir -r requirements.txt",
        "playwright install --with-deps firefox"
      ]
    }
  },
  "deploy": {
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8001}"
  }
}
